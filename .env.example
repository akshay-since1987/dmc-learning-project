# Copy this file to .env and fill in your values before running docker compose up.
# NEVER commit .env to source control.

# ─────────────────────────────────────────────────────────────
# SQL Server
# ─────────────────────────────────────────────────────────────
# Password for the SQL Server 'sa' account.
# Must meet SQL Server complexity requirements:
#   ≥ 8 chars, upper + lower + digit + symbol
SQL_SA_PASSWORD=YourStrong!Passw0rd

# Host port to expose SQL Server on (default 1433).
# Change if 1433 is already in use on your server.
SQL_PORT=1433

# ─────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────
# Host port for the API (mapped to container port 8080)
APP_PORT=5111

# ASP.NET Core environment: Production | Staging | Development
ASPNETCORE_ENVIRONMENT=Production

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
# Must be ≥ 32 characters. Use a strong random string in production.
JWT_KEY=Replace-With-A-Long-Random-Secret-Key-That-Is-At-Least-32-Chars!
JWT_ISSUER=ProposalManagement.Api
JWT_AUDIENCE=ProposalManagement.Client
JWT_ACCESS_EXPIRY_MINUTES=15
JWT_REFRESH_EXPIRY_DAYS=7

# ─────────────────────────────────────────────────────────────
# OTP
# ─────────────────────────────────────────────────────────────
# Set to false in production. Set to true + provide OTP_DEFAULT for testing.
OTP_SIMULATE=false
OTP_DEFAULT=

# ─────────────────────────────────────────────────────────────
# SMS Gateway
# ─────────────────────────────────────────────────────────────
SMS_API_URL=
SMS_API_KEY=
SMS_HTTP_METHOD=GET
