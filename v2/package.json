{
  "name": "proposal-management-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Build tooling for ProposalManagement frontend (minify CSS/JS)",
  "scripts": {
    "build:css": "npx clean-css-cli -o backend/src/ProposalManagement.Api/wwwroot/css/app.min.css backend/src/ProposalManagement.Api/wwwroot/css/app.css",
    "build:js": "npx terser backend/src/ProposalManagement.Api/wwwroot/js/app.js backend/src/ProposalManagement.Api/wwwroot/js/api.js backend/src/ProposalManagement.Api/wwwroot/js/auth.js backend/src/ProposalManagement.Api/wwwroot/js/router.js backend/src/ProposalManagement.Api/wwwroot/js/layout.js backend/src/ProposalManagement.Api/wwwroot/js/i18n.js backend/src/ProposalManagement.Api/wwwroot/js/dual-lang-input.js backend/src/ProposalManagement.Api/wwwroot/js/toast.js backend/src/ProposalManagement.Api/wwwroot/js/utils.js backend/src/ProposalManagement.Api/wwwroot/js/signature-overlay.js --compress --mangle -o backend/src/ProposalManagement.Api/wwwroot/js/app.min.js",
    "build": "npm run build:css && npm run build:js",
    "dev": "echo Development mode — files served unminified from wwwroot"
  },
  "devDependencies": {
    "clean-css-cli": "^5.6.3",
    "terser": "^5.31.0"
  }
}
